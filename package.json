{
  "type": "module",
  "name": "velkonix-ui-v2",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm"
  },
  "scripts": {
    "preinstall": "npx -y only-allow pnpm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint:colors": "node scripts/check-no-hardcoded-colors.mjs",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run test:unit && pnpm run test:e2e",
    "test:unit": "jest --config jest.config.ts",
    "e2e:install": "PLAYWRIGHT_BROWSERS_PATH=0 playwright install chromium",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --config=playwright.config.ts",
    "test:e2e:ci": "PLAYWRIGHT_BROWSERS_PATH=0 playwright test --config=playwright.config.ts",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Velkonix/velkonix-ui-v2.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/Velkonix/velkonix-ui-v2/issues"
  },
  "homepage": "https://github.com/Velkonix/velkonix-ui-v2#readme",
  "dependencies": {
    "@aave/contract-helpers": "1.21.1",
    "@aave/math-utils": "1.21.1",
    "@rainbow-me/rainbowkit": "2.2.10",
    "@tanstack/react-query": "5.90.20",
    "bignumber.js": "9.3.1",
    "ethers": "5.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "19.2.4",
    "react-router-dom": "7.13.0",
    "recharts": "3.7.0",
    "viem": "2.45.2",
    "wagmi": "2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.58.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/eslint": "9.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.3",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "jest": "30.2.0",
    "jest-environment-jsdom": "30.2.0",
    "lint-staged": "15",
    "prettier": "3.8.3",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.0",
    "vite": "7.3.1"
  }
}
